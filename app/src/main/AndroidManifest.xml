<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Essential Permissions Only -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ✅ THÊM: Camera và External Storage permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- ✅ Camera Feature (optional) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- ===== MAIN ACTIVITY ===== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.DayNight">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== AUTH ACTIVITIES ===== -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <activity
            android:name=".ui.auth.OtpVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <activity
            android:name=".ui.auth.ResetPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <!-- ===== PRODUCT ACTIVITIES ===== -->
        <activity
            android:name=".ui.product.ProductDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.product.AddProductActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />


        <!-- ===== PROFILE ACTIVITIES ===== -->
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.MyListingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.SavedItemsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />



        <activity
            android:name=".ui.profile.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.UserProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== 🔥 THÊM MỚI: TRANSACTION ACTIVITIES ===== -->
        <activity
            android:name=".ui.transaction.TransactionHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.transaction.TransactionDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".ui.transaction.TransactionHistoryActivity" />

        <!-- ===== REVIEW ACTIVITIES ===== -->
        <activity
            android:name=".ui.review.WriteReviewActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.review.ReviewListActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== CHAT ACTIVITIES ===== -->
        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== SEARCH ACTIVITIES ===== -->
        <activity
            android:name=".ui.search.AllProductsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.product.CategoryProductsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.product.EditProductActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== LOCATION ACTIVITIES ===== -->
        <activity
            android:name=".ui.location.RealtimeLocationActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ✅ THÊM: FileProvider cho camera/gallery image handling -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.newtrade.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>