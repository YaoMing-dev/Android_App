<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Essential Permissions Only -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ✅ THÊM: Camera và External Storage permissions -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- ✅ Camera Feature (optional) -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!-- ===== MAIN ACTIVITY ===== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.DayNight">
            <!-- ✅ SỬA: Chỉ có MAIN launcher intent, không có action VIEW -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== AUTHENTICATION ACTIVITIES ===== -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".ui.auth.LoginActivity" />

        <activity
            android:name=".ui.auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".ui.auth.LoginActivity" />

        <activity
            android:name=".ui.auth.OtpVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".ui.auth.LoginActivity" />

        <!-- ✅ SỬA: ResetPasswordActivity với Deep Link support -->
        <activity
            android:name=".ui.auth.ResetPasswordActivity"
            android:exported="true"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:screenOrientation="portrait"
            android:parentActivityName=".ui.auth.LoginActivity">

            <!-- ✅ THÊM: Deep Link Intent Filter cho email reset links -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Backend sẽ gửi link dạng: https://tradeup.app/reset-password?token=xxx&email=xxx -->
                <data android:scheme="https"
                    android:host="tradeup.app"
                    android:pathPrefix="/reset-password" />
            </intent-filter>

            <!-- ✅ THÊM: Custom scheme fallback cho testing -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <!-- Cho testing: tradeup://reset-password?token=xxx&email=xxx -->
                <data android:scheme="tradeup"
                    android:host="reset-password" />
            </intent-filter>
        </activity>

        <!-- ===== PRODUCT ACTIVITIES ===== -->
        <activity
            android:name=".ui.product.ProductDetailActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.product.AddProductActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== PROFILE ACTIVITIES ===== -->
        <activity
            android:name=".ui.profile.EditProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.SettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.MyListingsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.SavedItemsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.profile.UserProfileActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== CHAT ACTIVITIES ===== -->
        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== SEARCH ACTIVITIES ===== -->
        <activity
            android:name=".ui.search.AllProductsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <activity
            android:name=".ui.search.CategoryProductsActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ===== LOCATION ACTIVITIES ===== -->
        <activity
            android:name=".ui.location.RealtimeLocationActivity"
            android:exported="false"
            android:theme="@style/Theme.Material3.DayNight.NoActionBar"
            android:parentActivityName=".MainActivity" />

        <!-- ✅ THÊM: FileProvider cho camera/gallery image handling -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.newtrade.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ✅ THÊM: Firebase Messaging Service (nếu dùng push notifications) -->


    </application>

</manifest>