<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Button Styles -->
    <style name="AppButton" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <style name="AppButton.Primary" parent="AppButton">
        <item name="backgroundTint">@color/primary_color</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="AppButton.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="strokeColor">@color/primary_color</item>
        <item name="android:textColor">@color/primary_color</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>

    <!-- Text Input Layout Styles -->
    <style name="AppTextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_color</item>
        <item name="hintTextColor">@color/primary_color</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_md</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_md</item>
    </style>

    <!-- Card Styles -->
    <style name="AppCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">@dimen/elevation_sm</item>
        <item name="android:layout_margin">@dimen/margin_sm</item>
    </style>

    <!-- Chip Styles -->
    <style name="AppChip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">@dimen/radius_lg</item>
        <item name="android:textSize">@dimen/text_size_sm</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipBackgroundColor">@color/background_gray</item>
    </style>

    <!-- Toolbar Styles -->
    <style name="AppToolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/text_primary</item>
        <item name="subtitleTextColor">@color/text_secondary</item>
        <item name="android:background">@color/white</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="AppBottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_color_selector</item>
        <item name="itemTextColor">@color/bottom_nav_color_selector</item>
        <item name="android:background">@color/white</item>
        <item name="elevation">@dimen/elevation_lg</item>
    </style>

    <!-- Tab Layout Styles -->
    <style name="AppTabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabIndicatorColor">@color/primary_color</item>
        <item name="tabSelectedTextColor">@color/primary_color</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="android:background">@color/white</item>
    </style>

    <!-- Dialog Styles -->
    <style name="AppDialog" parent="ThemeOverlay.Material3.Dialog">
        <item name="dialogCornerRadius">@dimen/radius_lg</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <style name="AppDialog.Alert" parent="ThemeOverlay.Material3.Dialog.Alert">
        <item name="dialogCornerRadius">@dimen/radius_lg</item>
        <item name="buttonBarPositiveButtonStyle">@style/AppButton.Primary</item>
        <item name="buttonBarNegativeButtonStyle">@style/AppButton.Secondary</item>
    </style>

    <!-- Bottom Sheet Styles -->
    <style name="AppBottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/AppBottomSheet</item>
    </style>

    <style name="AppBottomSheet" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/AppBottomSheetShape</item>
        <item name="android:background">@color/white</item>
    </style>

    <style name="AppBottomSheetShape" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/bottom_sheet_corner_radius</item>
        <item name="cornerSizeTopRight">@dimen/bottom_sheet_corner_radius</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.App.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">@dimen/text_size_headline</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">@dimen/text_size_xxl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">@dimen/text_size_xl</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.App.Subtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">@dimen/text_size_lg</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">@dimen/text_size_md</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">@dimen/text_size_sm</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>