<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Newtrade" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_light</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/secondary_color</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/secondary_dark</item>

        <!-- Error Colors -->
        <item name="colorError">@color/error_color</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/error_color</item>
        <item name="colorOnErrorContainer">@color/white</item>

        <!-- Surface Colors -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/background_gray</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <!-- FIX: Thay colorBackground thành android:colorBackground -->
        <item name="android:colorBackground">@color/background_light</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <!-- Outline Colors -->
        <item name="colorOutline">@color/divider_color</item>

        <!-- System bars -->
        <item name="android:statusBarColor" >@color/primary_dark</item>
        <item name="android:navigationBarColor" >@color/white</item>
        <item name="android:windowLightStatusBar" >false</item>


        <!-- Window properties -->
        <item name="android:windowBackground">@color/background_light</item>

        <!-- Material Design 3 Component Styles -->
        <item name="materialButtonStyle">@style/AppButton</item>
        <item name="textInputStyle">@style/AppTextInputLayout</item>
        <item name="materialCardViewStyle">@style/AppCard</item>
        <item name="chipStyle">@style/AppChip</item>
        <item name="toolbarStyle">@style/AppToolbar</item>
        <item name="bottomNavigationStyle">@style/AppBottomNavigation</item>
        <item name="tabStyle">@style/AppTabLayout</item>

        <!-- Dialog styles -->
        <item name="materialAlertDialogTheme">@style/AppDialog.Alert</item>
        <item name="bottomSheetDialogTheme">@style/AppBottomSheetDialog</item>

        <!-- Typography -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.App.Headline1</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.App.Headline2</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.App.Title</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.App.Subtitle</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.App.Body</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.App.Caption</item>
    </style>

    <style name="Theme.Newtrade" parent="Base.Theme.Newtrade" />

    <style name="SplashTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_gradient</item>
        <item name="android:statusBarColor">@color/splash_gradient_start</item>
        <item name="android:navigationBarColor">@color/splash_gradient_end</item>
        <item name="android:windowLightStatusBar">false</item>

    </style>

</resources>