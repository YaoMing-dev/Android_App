<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res/auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/product_card_width"
    android:layout_height="@dimen/product_card_height"
    android:layout_marginEnd="@dimen/margin_md"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="@dimen/elevation_md"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Product Image Container -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/product_image_height">

            <ImageView
                android:id="@+id/iv_product_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/light_gray"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- Featured Badge -->
            <TextView
                android:id="@+id/tv_featured_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="@dimen/margin_sm"
                android:background="@drawable/rounded_background_primary"
                android:paddingHorizontal="@dimen/padding_sm"
                android:paddingVertical="@dimen/padding_xs"
                android:text="Featured"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xs"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <!-- Save Button -->
            <ImageView
                android:id="@+id/iv_save_product"
                android:layout_width="@dimen/icon_size_lg"
                android:layout_height="@dimen/icon_size_lg"
                android:layout_gravity="top|end"
                android:layout_margin="@dimen/margin_sm"
                android:background="@drawable/circle_background_white"
                android:padding="@dimen/padding_sm"
                android:src="@drawable/ic_bookmark_border"
                app:tint="@color/text_secondary" />

            <!-- Distance Badge -->
            <TextView
                android:id="@+id/tv_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="@dimen/margin_sm"
                android:background="@drawable/rounded_background_dark"
                android:paddingHorizontal="@dimen/padding_sm"
                android:paddingVertical="@dimen/padding_xs"
                android:text="2.5 km"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_xs"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

        </FrameLayout>

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/padding_md">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_product_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_md"
                android:textStyle="bold"
                android:lineSpacingExtra="1dp"
                tools:text="iPhone 13 Pro Max 256GB" />

            <!-- Price -->
            <TextView
                android:id="@+id/tv_product_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_sm"
                android:textColor="@color/primary_color"
                android:textSize="@dimen/text_size_lg"
                android:textStyle="bold"
                tools:text="₫18,500,000" />

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Bottom Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="@dimen/icon_size_sm"
                    android:layout_height="@dimen/icon_size_sm"
                    android:src="@drawable/ic_location"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_product_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/margin_xs"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_xs"
                    tools:text="District 1" />

                <TextView
                    android:id="@+id/tv_time_posted"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_xs"
                    tools:text="2h" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>