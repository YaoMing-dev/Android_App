<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- AppBar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="@dimen/elevation_md">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/add_product"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:menu="@menu/add_product_menu" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_lg">

            <!-- Photo Upload Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_photos"
                        android:textSize="@dimen/text_size_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xs"
                        android:text="Add up to 10 photos. First photo will be the cover image."
                        android:textSize="@dimen/text_size_md"
                        android:textColor="@color/text_secondary" />

                    <!-- Photo Grid -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_photos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:nestedScrollingEnabled="false"
                        tools:itemCount="3"
                        tools:listitem="@layout/item_photo_upload" />

                    <!-- Add Photo Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_photo"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/margin_md"
                        android:text="@string/upload_photos"
                        app:icon="@drawable/ic_camera"
                        app:iconGravity="textStart" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Product Details Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/product_details"
                        android:textSize="@dimen/text_size_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Title Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_title"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true"
                        app:counterEnabled="true"
                        app:counterMaxLength="100">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences"
                            android:maxLength="100" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Description Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_description"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true"
                        app:counterEnabled="true"
                        app:counterMaxLength="500">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_description"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:minLines="3"
                            android:maxLines="5"
                            android:maxLength="500"
                            android:gravity="top" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Category Selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_category"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_category"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true">

                        <AutoCompleteTextView
                            android:id="@+id/et_category"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            tools:text="Electronics" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Condition Selection -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_condition"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_condition"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true">

                        <AutoCompleteTextView
                            android:id="@+id/et_condition"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            tools:text="Like New" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Price & Location Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Price &amp; Location"
                        android:textSize="@dimen/text_size_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Price Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_price"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_price"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true"
                        app:startIconDrawable="@drawable/ic_currency"
                        app:helperText="Enter 0 for free items">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_price"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Negotiable Checkbox -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/cb_negotiable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_md"
                        android:text="@string/negotiate_price"
                        android:textColor="@color/text_primary" />

                    <!-- Location Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_location"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="@string/product_location"
                        app:boxStrokeColor="@color/primary_color"
                        app:errorEnabled="true"
                        app:startIconDrawable="@drawable/ic_location"
                        app:endIconMode="custom"
                        app:endIconDrawable="@drawable/ic_my_location">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_location"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapWords" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Use Current Location Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_current_location"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_sm"
                        android:layout_marginTop="@dimen/margin_md"
                        android:text="@string/use_current_location"
                        app:icon="@drawable/ic_gps_fixed"
                        app:iconSize="@dimen/icon_size_sm" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Additional Options Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_xl"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_sm">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Additional Options"
                        android:textSize="@dimen/text_size_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <!-- Tags Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_tags"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:hint="Tags (Optional)"
                        app:boxStrokeColor="@color/primary_color"
                        app:helperText="Add keywords separated by commas">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_tags"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Options Checkboxes -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_lg"
                        android:orientation="vertical">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cb_highlight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Highlight this listing (Premium)"
                            android:textColor="@color/text_primary" />

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cb_auto_renew"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_sm"
                            android:text="Auto-renew listing every 30 days"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="@dimen/elevation_lg"
        android:orientation="horizontal"
        android:padding="@dimen/padding_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_preview"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginEnd="@dimen/margin_md"
            android:layout_weight="1"
            android:text="Preview"
            app:icon="@drawable/ic_preview" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_publish"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_weight="2"
            android:text="Publish Listing"
            app:icon="@drawable/ic_publish" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>