<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sort Products"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="16dp" />

    <!-- Sort Options -->
    <RadioGroup
        android:id="@+id/rg_sort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rb_relevance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Best Match"
            android:textSize="16sp"
            android:padding="12dp" />

        <RadioButton
            android:id="@+id/rb_newest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Newest First"
            android:textSize="16sp"
            android:padding="12dp" />

        <RadioButton
            android:id="@+id/rb_oldest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Oldest First"
            android:textSize="16sp"
            android:padding="12dp" />

        <RadioButton
            android:id="@+id/rb_price_low_high"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price: Low to High"
            android:textSize="16sp"
            android:padding="12dp" />

        <RadioButton
            android:id="@+id/rb_price_high_low"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Price: High to Low"
            android:textSize="16sp"
            android:padding="12dp" />

        <RadioButton
            android:id="@+id/rb_nearby"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nearest First"
            android:textSize="16sp"
            android:padding="12dp" />

    </RadioGroup>

</LinearLayout>