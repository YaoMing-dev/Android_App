<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:elevation="@dimen/elevation_md">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Choose Location"
            app:navigationIcon="@drawable/ic_arrow_back" />

        <!-- Search Bar -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_search_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/margin_lg"
            android:layout_marginBottom="@dimen/margin_md"
            android:hint="@string/search_location"
            app:startIconDrawable="@drawable/ic_search"
            app:endIconMode="clear_text"
            app:boxStrokeColor="@color/primary_color">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/et_search_location"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:imeOptions="actionSearch" />

        </com.google.android.material.textfield.TextInputLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Map Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Google Map -->
        <fragment
            android:id="@+id/map_fragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- Center Marker -->
        <ImageView
            android:layout_width="@dimen/icon_size_xl"
            android:layout_height="@dimen/icon_size_xl"
            android:layout_gravity="center"
            android:layout_marginBottom="@dimen/margin_lg"
            android:src="@drawable/ic_location_pin"
            app:tint="@color/primary_color" />

        <!-- Current Location FAB -->
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab_current_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/margin_lg"
            android:layout_marginBottom="100dp"
            android:src="@drawable/ic_my_location"
            app:tint="@color/white" />

    </FrameLayout>

    <!-- Bottom Sheet with Location Info -->
    <LinearLayout
        android:id="@+id/ll_location_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="@dimen/elevation_lg"
        android:orientation="vertical"
        android:padding="@dimen/padding_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Selected Location"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tv_selected_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_sm"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_md"
            tools:text="123 Main Street, District 1, Ho Chi Minh City" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm_location"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginTop="@dimen/margin_lg"
            android:text="Confirm Location"
            app:icon="@drawable/ic_check" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>