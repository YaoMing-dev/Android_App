<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App Bar with Collapsing Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/product_detail_image_height"
        android:theme="@style/ThemeOverlay.Material3.Dark">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/primary_color"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:statusBarScrim="@color/primary_dark">

            <!-- Product Images ViewPager -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/vp_product_images"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax" />

            <!-- Image Indicators -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tab_indicators"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="@dimen/margin_lg"
                android:background="@drawable/rounded_background_dark"
                app:tabBackground="@drawable/tab_indicator_selector"
                app:tabGravity="center"
                app:tabIndicatorHeight="0dp"
                app:tabMaxWidth="8dp"
                app:tabMinWidth="8dp" />

            <!-- Toolbar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:navigationIcon="@drawable/ic_arrow_back"
                app:menu="@menu/product_detail_menu" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Product Info Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg">

                <!-- Title & Price -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_product_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_xl"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp"
                        tools:text="iPhone 13 Pro Max 256GB - Blue, Excellent Condition" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_md"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_product_price"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/primary_color"
                            android:textSize="@dimen/text_size_xxl"
                            android:textStyle="bold"
                            tools:text="₫18,500,000" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_condition"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Like New"
                            app:chipBackgroundColor="@color/condition_like_new"
                            android:textColor="@color/white"
                            tools:text="Like New" />

                    </LinearLayout>

                    <!-- Negotiable Badge -->
                    <TextView
                        android:id="@+id/tv_negotiable"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_sm"
                        android:background="@drawable/rounded_background_primary"
                        android:paddingHorizontal="@dimen/padding_md"
                        android:paddingVertical="@dimen/padding_xs"
                        android:text="@string/negotiate_price"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_sm"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_lg"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/icon_size_sm"
                            android:layout_height="@dimen/icon_size_sm"
                            android:src="@drawable/ic_visibility"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_views_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_sm"
                            tools:text="245 views" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/icon_size_sm"
                            android:layout_height="@dimen/icon_size_sm"
                            android:src="@drawable/ic_favorite"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_saves_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_sm"
                            tools:text="12 saved" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="@dimen/icon_size_sm"
                            android:layout_height="@dimen/icon_size_sm"
                            android:src="@drawable/ic_schedule"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tv_posted_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/margin_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_sm"
                            tools:text="2 days ago" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider_color" />

            <!-- Description Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Description"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_product_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_md"
                    tools:text="iPhone 13 Pro Max in excellent condition. Only used for 6 months with screen protector and case. Battery health is 98%. Includes original box, charger, and documentation." />

                <!-- Show More/Less -->
                <TextView
                    android:id="@+id/tv_show_more"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_sm"
                    android:text="Show more"
                    android:textColor="@color/primary_color"
                    android:textSize="@dimen/text_size_md"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider_color" />

            <!-- Location Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_location"
                        app:tint="@color/primary_color" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_product_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_md"
                            android:textStyle="bold"
                            tools:text="District 1, Ho Chi Minh City" />

                        <TextView
                            android:id="@+id/tv_distance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_sm"
                            tools:text="2.5 km from your location" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_map"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_sm"
                        android:text="View Map"
                        app:icon="@drawable/ic_map"
                        app:iconSize="@dimen/icon_size_sm" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider_color" />

            <!-- Seller Section -->
            <LinearLayout
                android:id="@+id/ll_seller_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/seller_info"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_seller_avatar"
                        android:layout_width="@dimen/avatar_size_xl"
                        android:layout_height="@dimen/avatar_size_xl"
                        android:src="@drawable/placeholder_avatar"
                        tools:src="@tools:sample/avatars" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_md"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_seller_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_lg"
                            android:textStyle="bold"
                            tools:text="John Doe" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xs"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="@dimen/star_size"
                                android:layout_height="@dimen/star_size"
                                android:src="@drawable/ic_star"
                                app:tint="@color/star_color" />

                            <TextView
                                android:id="@+id/tv_seller_rating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_xs"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_size_md"
                                android:textStyle="bold"
                                tools:text="4.8" />

                            <TextView
                                android:id="@+id/tv_seller_reviews"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_xs"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_size_sm"
                                tools:text="(24 reviews)" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_member_since"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_xs"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_sm"
                            tools:text="Member since Dec 2022" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_view_profile"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/button_height_sm"
                        android:text="View Profile"
                        app:icon="@drawable/ic_person" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider_color" />

            <!-- Related Products Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Similar Products"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_related_products"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:orientation="horizontal"
                    android:clipToPadding="false"
                    android:paddingEnd="@dimen/padding_lg"
                    tools:itemCount="3"
                    tools:listitem="@layout/item_product_featured" />

            </LinearLayout>

            <!-- Bottom Spacing for FAB -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        android:elevation="@dimen/elevation_lg"
        android:orientation="horizontal"
        android:padding="@dimen/padding_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="@dimen/button_height_lg"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginEnd="@dimen/margin_md"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            app:icon="@drawable/ic_bookmark_border"
            app:iconGravity="textStart"
            app:iconPadding="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_message"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginEnd="@dimen/margin_md"
            android:layout_weight="1"
            android:text="Message"
            app:icon="@drawable/ic_chat" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_make_offer"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_weight="1"
            android:text="@string/make_offer"
            app:icon="@drawable/ic_local_offer" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>