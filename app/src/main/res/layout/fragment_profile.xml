<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- App Bar with Collapsing Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/profile_header_height"
        android:background="@color/primary_color"
        android:theme="@style/ThemeOverlay.Material3.Dark">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="@color/primary_color"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:statusBarScrim="@color/primary_dark">

            <!-- Profile Header Content -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg"
                app:layout_collapseMode="parallax">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/iv_profile_avatar"
                    android:layout_width="@dimen/avatar_size_profile"
                    android:layout_height="@dimen/avatar_size_profile"
                    android:src="@drawable/placeholder_avatar"
                    tools:src="@tools:sample/avatars" />

                <TextView
                    android:id="@+id/tv_display_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_lg"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_xxl"
                    android:textStyle="bold"
                    tools:text="John Doe" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_sm"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="@dimen/star_size_lg"
                        android:layout_height="@dimen/star_size_lg"
                        android:src="@drawable/ic_star"
                        app:tint="@color/star_color" />

                    <TextView
                        android:id="@+id/tv_rating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_xs"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_lg"
                        android:textStyle="bold"
                        tools:text="4.8" />

                    <TextView
                        android:id="@+id/tv_reviews_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_sm"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_md"
                        android:alpha="0.8"
                        tools:text="(24 reviews)" />

                </LinearLayout>

            </LinearLayout>

            <!-- Toolbar -->
            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                app:layout_collapseMode="pin"
                app:menu="@menu/profile_menu" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Stats Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="horizontal"
                android:padding="@dimen/padding_lg">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_listings_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary_color"
                        android:textSize="@dimen/text_size_xxl"
                        android:textStyle="bold"
                        tools:text="12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xs"
                        android:text="Listings"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_sold_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/success_color"
                        android:textSize="@dimen/text_size_xxl"
                        android:textStyle="bold"
                        tools:text="8" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xs"
                        android:text="Sold"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_bought_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/info_color"
                        android:textSize="@dimen/text_size_xxl"
                        android:textStyle="bold"
                        tools:text="15" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xs"
                        android:text="Bought"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_member_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/warning_color"
                        android:textSize="@dimen/text_size_xxl"
                        android:textStyle="bold"
                        tools:text="2Y" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/margin_xs"
                        android:text="Member"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm" />

                </LinearLayout>

            </LinearLayout>

            <!-- Bio Section -->
            <LinearLayout
                android:id="@+id/ll_bio_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical"
                android:padding="@dimen/padding_lg"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_lg"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_bio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/margin_md"
                    android:lineSpacingExtra="2dp"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_md"
                    tools:text="Tech enthusiast and collector. I sell carefully maintained electronics and gadgets. All items are tested and come with detailed descriptions." />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height"
                android:background="@color/divider_color" />

            <!-- Menu Items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <!-- My Listings -->
                <LinearLayout
                    android:id="@+id/ll_my_listings"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_list"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/my_listings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <TextView
                        android:id="@+id/tv_listings_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_md"
                        android:background="@drawable/rounded_background_primary"
                        android:paddingHorizontal="@dimen/padding_sm"
                        android:paddingVertical="@dimen/padding_xs"
                        android:text="3"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_size_xs"
                        android:textStyle="bold"
                        tools:text="12" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- Saved Items -->
                <LinearLayout
                    android:id="@+id/ll_saved_items"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_bookmark"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/saved_items"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- Purchase History -->
                <LinearLayout
                    android:id="@+id/ll_purchase_history"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_shopping_bag"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/purchase_history"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- Reviews -->
                <LinearLayout
                    android:id="@+id/ll_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_rate_review"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/reviews"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/divider_height_thick"
                android:background="@color/divider_color" />

            <!-- Settings Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/white"
                android:orientation="vertical">

                <!-- Account Settings -->
                <LinearLayout
                    android:id="@+id/ll_account_settings"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/account_settings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- Help & Support -->
                <LinearLayout
                    android:id="@+id/ll_help_support"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_help"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/help_support"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- About -->
                <LinearLayout
                    android:id="@+id/ll_about"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_info"
                        app:tint="@color/text_secondary" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/about"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_md" />

                    <TextView
                        android:id="@+id/tv_version"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/margin_md"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_sm"
                        tools:text="v1.0.0" />

                    <ImageView
                        android:layout_width="@dimen/icon_size_md"
                        android:layout_height="@dimen/icon_size_md"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/text_secondary" />

                </LinearLayout>

                <!-- Logout -->
                <LinearLayout
                    android:id="@+id/ll_logout"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/list_item_height_lg"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_lg">

                    <ImageView
                        android:layout_width="@dimen/icon_size_lg"
                        android:layout_height="@dimen/icon_size_lg"
                        android:src="@drawable/ic_logout"
                        app:tint="@color/error_color" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/margin_lg"
                        android:layout_weight="1"
                        android:text="@string/logout"
                        android:textColor="@color/error_color"
                        android:textSize="@dimen/text_size_md" />

                </LinearLayout>

            </LinearLayout>

            <!-- Bottom Spacing -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/margin_xxl" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Edit Profile FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_edit_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/margin_lg"
        android:src="@drawable/ic_edit"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>