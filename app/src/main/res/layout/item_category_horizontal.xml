<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/category_item_width"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/margin_md"
    android:background="?attr/selectableItemBackground"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/padding_md">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="@dimen/category_item_height"
        android:layout_height="@dimen/category_item_height"
        app:cardCornerRadius="@dimen/radius_lg"
        app:cardElevation="@dimen/elevation_sm"
        app:strokeWidth="0dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_gray">

            <ImageView
                android:id="@+id/iv_category_icon"
                android:layout_width="@dimen/category_icon_size"
                android:layout_height="@dimen/category_icon_size"
                android:layout_gravity="center"
                android:src="@drawable/ic_category_electronics"
                app:tint="@color/category_electronics"
                tools:src="@drawable/ic_smartphone"
                tools:tint="@color/category_electronics" />

        </FrameLayout>

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tv_category_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_sm"
        android:textStyle="bold"
        tools:text="Electronics" />

    <TextView
        android:id="@+id/tv_item_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_xs"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_xs"
        tools:text="245 items" />

</LinearLayout>