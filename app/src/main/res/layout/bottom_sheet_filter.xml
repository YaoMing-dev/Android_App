<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/padding_lg">

    <!-- Handle Bar -->
    <View
        android:layout_width="@dimen/bottom_sheet_handle_width"
        android:layout_height="@dimen/bottom_sheet_handle_height"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="@dimen/bottom_sheet_handle_margin"
        android:background="@drawable/bottom_sheet_handle" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_marginBottom="@dimen/margin_lg">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filters"
            android:textSize="@dimen/text_size_xl"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/tv_clear_all"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/clear_all"
            android:textColor="@color/primary_color"
            android:textStyle="bold"
            android:background="?attr/selectableItemBackground"
            android:padding="@dimen/padding_sm" />

    </LinearLayout>

    <!-- Price Range -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/price_range"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_md"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_min_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/margin_md"
                android:layout_weight="1"
                android:hint="@string/min_price"
                app:boxStrokeColor="@color/primary_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_min_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />

            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_max_price"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/max_price"
                app:boxStrokeColor="@color/primary_color">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_max_price"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />

            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Category Filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/product_category"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_categories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_md"
            app:chipSpacingHorizontal="@dimen/margin_sm"
            app:chipSpacingVertical="@dimen/margin_sm"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_electronics"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_electronics" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_fashion"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_fashion" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_home"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_home_garden" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_sports"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/category_sports" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- Condition Filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/product_condition"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_conditions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_md"
            app:chipSpacingHorizontal="@dimen/margin_sm"
            app:singleSelection="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_new"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/condition_new" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_like_new"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/condition_like_new" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_good"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/condition_good" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_fair"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/condition_fair" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- Distance Filter -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="@dimen/margin_lg">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/distance_range"
            android:textSize="@dimen/text_size_lg"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_distance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_md"
            app:chipSpacingHorizontal="@dimen/margin_sm"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_any_distance"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                android:text="@string/any_distance" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_1km"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/within_1km" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_5km"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/within_5km" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_10km"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/within_10km" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/margin_lg">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_marginEnd="@dimen/margin_md"
            android:layout_weight="1"
            android:text="Reset" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_apply"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height_lg"
            android:layout_weight="2"
            android:text="@string/apply_filters" />

    </LinearLayout>

</LinearLayout>