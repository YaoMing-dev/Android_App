<?xml version="1.0" encoding="utf-8"?>
<!-- app/src/main/res/layout/item_product.xml -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ✅ ENHANCED: FrameLayout để chứa image, status badge, và overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp">

            <!-- Product Image -->
            <ImageView
                android:id="@+id/iv_product"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_image_placeholder"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- ✅ NEW: Status Overlay (for visual indication) -->
            <View
                android:id="@+id/v_status_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone"
                tools:background="#80000000"
                tools:visibility="visible" />

            <!-- ✅ ENHANCED: STATUS BADGE (top-right) -->
            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_status_badge"
                android:text="SOLD"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:visibility="gone"
                tools:visibility="visible"
                tools:text="SOLD" />

            <!-- ✅ NEW: Owner Actions (bottom-right, only visible for owner view) -->
            <LinearLayout
                android:id="@+id/ll_owner_actions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <!-- Analytics Button -->
                <ImageView
                    android:id="@+id/iv_analytics"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="4dp"
                    android:background="@drawable/bg_round_button"
                    android:padding="4dp"
                    android:src="@drawable/ic_analytics"
                    android:contentDescription="View Analytics"
                    app:tint="@color/white" />

                <!-- Status Change Button -->
                <ImageView
                    android:id="@+id/iv_status_change"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@drawable/bg_round_button"
                    android:padding="4dp"
                    android:src="@drawable/ic_edit"
                    android:contentDescription="Change Status"
                    app:tint="@color/white" />

            </LinearLayout>

        </FrameLayout>

        <!-- Product Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Product Title"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="4dp"
                tools:text="iPhone 14 Pro Max 256GB Deep Purple" />

            <!-- Price -->
            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₫0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="4dp"
                tools:text="₫25,000,000" />

            <!-- Location and Condition Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <!-- Location -->
                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Location"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:drawableStart="@drawable/ic_location"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Ho Chi Minh City" />

                <!-- Condition -->
                <TextView
                    android:id="@+id/tv_condition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New"
                    android:textSize="10sp"
                    android:textColor="@color/success"
                    android:background="@drawable/bg_condition_badge"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    tools:text="Like New" />

            </LinearLayout>

            <!-- Category -->
            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textSize="11sp"
                android:textColor="@color/text_hint"
                android:drawableStart="@drawable/ic_category"
                android:drawablePadding="4dp"
                android:drawableTint="@color/text_hint"
                tools:text="Electronics" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>